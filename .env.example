# ─────────────────────────────────────────────────────────────────────────────
# booking-backend — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────

# Port the Express server listens on (Render sets this automatically)
PORT=3001

# Node environment: development | test | production
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────

# Full Postgres connection string
# Local:      postgres://postgres:password@localhost:5432/bookflow
# Production: provided by Render or Supabase
DATABASE_URL=postgres://postgres:password@localhost:5432/bookflow

# Set to "true" to enable SSL for the DB connection (required on Render / Supabase)
DATABASE_SSL=false

# Connection pool tuning (optional — defaults shown)
PGPOOL_MAX=5
PGPOOL_IDLE=30000
PGPOOL_CONN_TIMEOUT=10000

# ── Auth & Security ───────────────────────────────────────────────────────────

# Secret key for platform-level admin routes (x-api-key or Authorization: Bearer header)
# Generate: openssl rand -hex 32
ADMIN_API_KEY=replace-with-a-strong-random-secret

# Shared secret used by the frontend to verify NextAuth JWTs passed to this backend
# Must match NEXTAUTH_SECRET in the frontend and auth service
NEXTAUTH_SECRET=replace-with-the-same-secret-as-frontend

# Comma-separated list of Google OAuth client IDs accepted by this backend
# Usually the same as GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_IDS=your-google-client-id.apps.googleusercontent.com

# ── CORS ──────────────────────────────────────────────────────────────────────

# Base URL of your Next.js frontend (used in CORS allowed-origins)
FRONTEND_URL=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000

# Set to "true" to also allow *.vercel.app preview deployment origins
ALLOW_VERCEL_PREVIEWS=false

# ── Stripe Billing ────────────────────────────────────────────────────────────

# Stripe secret key (sk_test_... for test mode, sk_live_... for production)
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_secret_key

# Signing secret from the Stripe dashboard webhook endpoint
# (used to verify incoming webhook payloads)
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_signing_secret

# Stripe Price IDs for each plan (from Stripe dashboard → Products)
STRIPE_PRICE_STARTER=price_replace_starter
STRIPE_PRICE_GROWTH=price_replace_growth
STRIPE_PRICE_PRO=price_replace_pro

# ── Cloudflare R2 Storage (optional — for media uploads) ─────────────────────

# S3-compatible endpoint for your R2 bucket
# e.g. https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# R2 access credentials (generate in Cloudflare dashboard → R2 → Manage API tokens)
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Bucket name
R2_BUCKET_NAME=bookflow-media

# Region (Cloudflare R2 always uses "auto")
R2_REGION=auto

# Public base URL for serving uploaded files (your R2 public domain or custom domain)
R2_PUBLIC_BASE_URL=https://pub-your-account.r2.dev

# ── Observability ─────────────────────────────────────────────────────────────

# Pino log level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info

# Sentry DSN for error tracking (leave blank to disable Sentry)
SENTRY_DSN=

# Human-readable service name shown in logs and health endpoint
SERVICE_NAME=booking-backend

# App version (auto-set by Render via RENDER_GIT_COMMIT; set manually in local dev)
APP_VERSION=local

# ── Misc ──────────────────────────────────────────────────────────────────────

# Number of days before a staff invite link expires (default: 7)
INVITE_EXPIRES_DAYS=7

# Set to "true" to expose /api/docs Swagger UI and other debug routes
ENABLE_DEBUG_ROUTES=false
